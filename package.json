{
  "name": "hensei-svelte",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 5174",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "lint": "prettier --check . && eslint .",
    "test:unit": "vitest",
    "test": "npm run test:unit -- --run",
    "test:adapters": "vitest run --config vitest.config.adapter.ts",
    "test:adapters:sandbox": "VITEST_POOL=forks vitest run --config vitest.config.adapter.ts",
    "test:adapters:watch": "vitest --config vitest.config.adapter.ts",
    "test:adapters:ui": "vitest --ui --config vitest.config.adapter.ts",
    "test:adapter:types": "tsc --noEmit -p tsconfig.json",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.3",
    "@eslint/compat": "^1.2.5",
    "@eslint/js": "^9.18.0",
    "@inlang/paraglide-js": "^2.0.0",
    "@storybook/addon-a11y": "^10.1.2",
    "@storybook/addon-docs": "^10.1.2",
    "@storybook/addon-svelte-csf": "^5.0.10",
    "@storybook/addon-vitest": "^10.1.2",
    "@storybook/blocks": "^8.6.14",
    "@storybook/sveltekit": "^10.1.2",
    "@sveltejs/adapter-node": "^5.2.12",
    "@sveltejs/kit": "^2.22.0",
    "@sveltejs/vite-plugin-svelte": "^6.0.0",
    "@tanstack/svelte-query-devtools": "^6.0.2",
    "@types/node": "^22",
    "@vitest/browser": "^3.2.3",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-storybook": "^10.1.2",
    "eslint-plugin-svelte": "^3.0.0",
    "globals": "^16.0.0",
    "playwright": "^1.53.0",
    "prettier": "^3.4.2",
    "prettier-plugin-svelte": "^3.3.3",
    "remark-gfm": "^4.0.1",
    "sass": "^1.92.1",
    "storybook": "^10.1.2",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "svelte-preprocess": "^6.0.3",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.20.0",
    "vite": "^7.0.4",
    "vitest": "^3.2.3",
    "vitest-browser-svelte": "^0.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "packageManager": "pnpm@10.15.1+sha512.34e538c329b5553014ca8e8f4535997f96180a1d0f614339357449935350d924e22f8614682191264ec33d1462ac21561aff97f6bb18065351c162c7e8f6de67",
  "dependencies": {
    "@friendofsvelte/tipex": "^0.0.9",
    "@internationalized/date": "^3.10.0",
    "@tanstack/svelte-query": "^6.0.9",
    "@tiptap/core": "^3.5.1",
    "@tiptap/extension-highlight": "^3.5.1",
    "@tiptap/extension-link": "^3.5.1",
    "@tiptap/pm": "^3.5.1",
    "@tiptap/starter-kit": "^3.5.1",
    "bits-ui": "^2.9.6",
    "fluid-dnd": "^2.6.2",
    "modern-normalize": "^3.0.1",
    "runed": "^0.31.1",
    "svelecte": "^5.3.0",
    "svelte-sonner": "^1.0.7",
    "wx-grid-data-provider": "^2.2.0",
    "wx-svelte-grid": "^2.0.0",
    "zod": "^4.1.5"
  }
}
